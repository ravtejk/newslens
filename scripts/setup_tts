#!/bin/bash
# NewsLens local-TTS engine setup (milestone 6, ADR-0008).
# Installs the ISOLATED Kokoro engine env: brew python@3.12 + kokoro-onnx in
# data/tts/venv + the two model artifacts (~340MB). The app itself stays on
# Python 3.9; the doctor's TTS check verifies this whole chain with a real
# short synthesis. Idempotent — safe to re-run.
set -euo pipefail
cd "$(dirname "$0")/.."
echo "== NewsLens TTS engine setup (Kokoro-82M local, isolated venv) =="
if ! command -v python3.12 >/dev/null 2>&1 && [ ! -x /opt/homebrew/bin/python3.12 ]; then
  echo "-> installing python@3.12 via Homebrew (one-time)"
  brew install python@3.12
fi
PY312="$(command -v python3.12 || echo /opt/homebrew/bin/python3.12)"
mkdir -p data/tts
if [ ! -x data/tts/venv/bin/python ]; then
  echo "-> creating engine venv (data/tts/venv)"
  "$PY312" -m venv data/tts/venv
  data/tts/venv/bin/pip install --quiet --upgrade pip
fi
echo "-> installing kokoro-onnx + soundfile into the engine venv"
data/tts/venv/bin/pip install --quiet kokoro-onnx soundfile
for f in kokoro-v1.0.onnx voices-v1.0.bin; do
  if [ ! -f "data/tts/$f" ]; then
    echo "-> downloading $f"
    curl -L --progress-bar -o "data/tts/$f" \
      "https://github.com/thewh1teagle/kokoro-onnx/releases/download/model-files-v1.0/$f"
  fi
done
echo "== done — verify with: scripts/doctor (TTS section) =="
