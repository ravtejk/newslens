#!/usr/bin/env python3
"""NewsLens doctor launcher.

Thin on purpose: bootstraps sys.path so the doctor runs BEFORE any
`pip install` has happened (fresh clone, system Python). All logic lives in
src/newslens/doctor.py; `newslens doctor` runs the identical code after
install. The checkout's src/ is prepended even when the package is installed,
so the doctor always diagnoses the code you're looking at.
"""

import sys
from pathlib import Path

PROTOTYPE_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PROTOTYPE_ROOT / "src"))

from newslens.doctor import main  # noqa: E402  (path bootstrap must run first)

if __name__ == "__main__":
    sys.exit(main())
