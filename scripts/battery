#!/usr/bin/env python3
"""NewsLens writer-battery launcher.

Thin on purpose (the scripts/doctor pattern): bootstraps sys.path so the runner
works from a fresh checkout, then delegates to src/newslens/battery.py. All logic
lives there and is offline-testable.

    scripts/battery --date 2026-07-16              # DRY RUN: plan + estimates only
    scripts/battery --date 2026-07-16 --run        # LIVE: real Opus/Sonnet/Fable calls
    scripts/battery --date 2026-07-16 --arms claude-opus-4-8,claude-sonnet-5

Dry-run is the default and makes ZERO calls and ZERO writes. --run makes the
live calls (needs ANTHROPIC_API_KEY), is bounded by BUDGET_CAP_USD_PER_RUN, and
NEVER touches the briefing of record — artifacts land under <DATA_DIR>/battery/.
"""

import sys
from pathlib import Path

PROTOTYPE_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PROTOTYPE_ROOT / "src"))

from newslens.battery import main  # noqa: E402  (path bootstrap must run first)

if __name__ == "__main__":
    sys.exit(main())
